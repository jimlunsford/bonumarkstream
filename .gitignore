# Public generated output and uploads
index.html
stream/
feed.xml
sitemap.xml
sitemap.xsl
robots.txt
media/*
!media/.gitkeep

# Local exports, logs, and archives
*.log
*.sql
*.sqlite
*.zip
*.tar
*.tar.gz
*.tgz

# OS and editor files
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo

